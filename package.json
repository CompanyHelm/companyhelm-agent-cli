{
  "name": "@companyhelm/agent-cli",
  "version": "0.0.4",
  "description": "Non-interactive CLI wrapper for CompanyHelm AgentTaskService.",
  "type": "module",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/CompanyHelm/companyhelm-agent-cli"
  },
  "engines": {
    "node": ">=24"
  },
  "bin": {
    "companyhelm-agent": "dist/cli.js"
  },
  "files": [
    "dist",
    "vendor"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
