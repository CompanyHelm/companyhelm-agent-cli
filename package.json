    "test:integration": "npm run build && vitest run tests/integration"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.11.0",
    "@companyhelm/protos": "^0.5.11",
    "@grpc/grpc-js": "^1.14.3",
    "commander": "^14.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.8.2",
    "vitest": "^2.1.8"
  }
}
